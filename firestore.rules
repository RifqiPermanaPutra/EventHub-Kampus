rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPanitia() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'panitia' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Collection Group Queries and Top-Level RSVPs
    match /{path=**}/rsvps/{rsvpId} {
      allow read: if isSignedIn();
    }
    
    match /rsvps/{rsvpId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || isPanitia(); // For check-in
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      (incoming().role == 'mahasiswa' || incoming().role == 'panitia' || incoming().role == 'admin') &&
                      incoming().keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
                      incoming().uid == userId;
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name']) || isAdmin();
    }

    // Event Rules
    match /events/{eventId} {
      allow read: if true; // Public can see approved events, but we should refine this
      allow list: if statusFilter() == 'approved' || isPanitia();
      
      function statusFilter() {
        return request.query.limit <= 100 && resource.data.status;
      }

      function isValidEvent(data) {
        return data.title is string && data.title.size() <= 100 &&
               data.description is string && data.description.size() <= 2000 &&
               data.category is string &&
               data.organizerId == request.auth.uid &&
               data.status in ['pending', 'approved', 'rejected'];
      }

      allow create: if isPanitia() && isValidEvent(incoming()) && incoming().status == 'pending';
      allow update: if (isPanitia() && existing().organizerId == request.auth.uid && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'date', 'location', 'posterUrl']) &&
                        isValidEvent(incoming())) ||
                      (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin() || (isPanitia() && existing().organizerId == request.auth.uid);

      // RSVPs subcollection
      match /rsvps/{rsvpId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(eventId);
        allow delete: if isOwner(existing().userId) || isAdmin();
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(eventId);
        allow delete: if isOwner(existing().userId) || isAdmin();
      }
    }

    // Notifications
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn(); // Allow any signed-in user to send notifications
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
    }
  }
}
